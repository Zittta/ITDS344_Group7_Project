# Environment variables (contains secrets – NEVER commit)
.env

# ── Airflow runtime ──────────────────────────────────────────────────────────
logs/
plugins/

# ── Data layer (large / generated files) ────────────────────────────────────
# Ignore all generated data...
data/

# ...but always keep the raw CSV seed file used by the Population DAG
!data/
!data/raw_csv/
!data/raw_csv/*.csv

# ── Kafka / streaming state ──────────────────────────────────────────────────
data/state/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

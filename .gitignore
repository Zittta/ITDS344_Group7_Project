# ── Secrets (ห้าม commit เด็ดขาด) ──────────────────────────────────────────
.env
*.env
.env.*

# ── Airflow runtime (generated — regenerated every run) ─────────────────────
logs/
plugins/

# ── Data layer (generated by DAGs / Kafka — stored in MongoDB) ──────────────
data/bronze/
data/silver/
data/gold/
# state/ เก็บ watermark ของ Kafka streaming — gitignore ได้
# (DAG watermarks อยู่ใน MongoDB, ส่วน Kafka state reset แล้ว re-process ได้)
data/state/

# เก็บ raw_csv/ ไว้ใน git (CSV ขนาดเล็ก, static, ต้องแชร์ให้ทีม)
!data/raw_csv/
!data/raw_csv/*.csv

# ── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
*.log

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

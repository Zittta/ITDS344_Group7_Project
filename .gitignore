# ── Secrets (ห้าม commit เด็ดขาด) ──────────────────────────────────────────
.env
*.env
.env.*

# ── Airflow runtime ──────────────────────────────────────────────────────────
logs/
plugins/

# ── Data layer (large / generated — ถูก generate โดย DAGs) ─────────────────
data/bronze/
data/silver/
data/gold/
data/state/
